# Copy this file to ".env" and fill in your key.
# The key is read only by the local dev server (vite.config.js) and is never
# bundled into the browser, because it has no VITE_ prefix.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for conversion (defaults to claude-opus-4-8)
# UG_CONVERT_MODEL=claude-opus-4-8
